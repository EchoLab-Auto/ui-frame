{
  "name": "@echolab/ui-frame",
  "version": "1.0.0",
  "description": "Vue 3 新拟态 UI 组件库",
  "type": "module",
  "main": "./dist/ui-frame.umd.cjs",
  "module": "./dist/ui-frame.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/ui-frame.js",
      "require": "./dist/ui-frame.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./doc": {
      "import": "./dist/doc/index.js",
      "types": "./dist/doc/index.d.ts"
    },
    "./extensions": {
      "import": "./dist/extensions/index.js",
      "types": "./dist/extensions/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./tokens.css": "./dist/tokens.css",
    "./base.css": "./dist/base.css",
    "./components/*": {
      "import": "./dist/components/*/index.js",
      "types": "./dist/components/*/index.d.ts"
    },
    "./composables/*": {
      "import": "./dist/composables/*.js",
      "types": "./dist/composables/*.d.ts"
    },
    "./locales": {
      "import": "./dist/locales/index.js",
      "types": "./dist/locales/index.d.ts"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "example": "vite --config examples/vite.config.ts --host",
    "example:build": "vite build --config examples/vite-build.config.ts",
    "example:preview": "vite preview --config examples/vite-build.config.ts --host",
    "build": "vue-tsc --noEmit && vite build && vite build --config vite.umd.config.ts",
    "build:types": "vue-tsc --noEmit false --declaration --emitDeclarationOnly",
    "changeset": "changeset",
    "clean": "rm -rf dist dist-example",
    "docs:build": "echo '📚 文档位于 docs/ 目录。如需构建演示站点，请使用: npm run example:build'",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.vue",
    "lint:fix": "eslint . --ext .ts,.tsx,.vue --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "node -e \"try{require('child_process').execSync('husky',{stdio:'inherit'})}catch(e){}\""
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{scss,css,json,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EchoLab-Auto/ui-frame.git"
  },
  "keywords": [
    "vue3",
    "vue",
    "ui",
    "component",
    "library",
    "neumorphism",
    "soft-ui",
    "design-system"
  ],
  "author": "EchoLab",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.10.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "sass": "^1.69.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vitest": "^4.1.8",
    "vue": "^3.4.0",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.2.12"
  },
  "dependencies": {
    "marked": "^18.0.5"
  }
}
