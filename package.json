{
  "name": "@echolab/ui-frame",
  "version": "1.0.0",
  "description": "A Vue 3 UI component library with Neumorphism design",
  "type": "module",
  "main": "./dist/ui-frame.umd.cjs",
  "module": "./dist/ui-frame.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/ui-frame.js",
      "require": "./dist/ui-frame.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "prepare": "vite build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EchoLab-Auto/ui-frame.git"
  },
  "keywords": [
    "vue3",
    "vue",
    "ui",
    "component",
    "library",
    "neumorphism",
    "soft-ui",
    "design-system"
  ],
  "author": "EchoLab",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "sass": "^1.69.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0",
    "vue": "^3.4.0",
    "vue-tsc": "^1.8.0"
  }
}
