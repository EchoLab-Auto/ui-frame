{
  "name": "@echolab/ui-frame",
  "version": "1.0.0",
  "description": "Vue 3 新拟态 UI 组件库",
  "type": "module",
  "main": "./dist/ui-frame.umd.cjs",
  "module": "./dist/ui-frame.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/ui-frame.js",
      "require": "./dist/ui-frame.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./dist/*": "./dist/*",
    "./composables/*": {
      "import": "./dist/composables/*",
      "types": "./dist/composables/*.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "example": "vite --config examples/vite.config.ts --host",
    "example:build": "vite build --config examples/vite-build.config.ts",
    "example:preview": "vite preview --config examples/vite-build.config.ts --host",
    "build": "vue-tsc --noEmit && vite build",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EchoLab-Auto/ui-frame.git"
  },
  "keywords": [
    "vue3",
    "vue",
    "ui",
    "component",
    "library",
    "neumorphism",
    "soft-ui",
    "design-system"
  ],
  "author": "EchoLab",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.1",
    "sass": "^1.69.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0",
    "vitest": "^4.1.8",
    "vue": "^3.4.0",
    "vue-tsc": "^2.2.12"
  }
}
